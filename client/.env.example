# ─── Backend API ─────────────────────────────────────────────────────────────
# Full URL of the backend REST API (must end with /api)
VITE_API_URL=https://miniproject-ckza.onrender.com/api

# ─── WebSocket ────────────────────────────────────────────────────────────────
# Full URL of the backend server for Socket.io (no /api suffix)
VITE_SOCKET_URL=https://miniproject-ckza.onrender.com

# ─── AI Service (optional) ────────────────────────────────────────────────────
# AI calls go through the Node backend proxy (/api/ai) by default.
# Only set this if you're running the FastAPI AI server at a different origin.
# VITE_AI_API_URL=http://localhost:8000
