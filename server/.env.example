# ─── AI Server ──────────────────────────────────────────────────────────────
# Port for the FastAPI AI microservice
PORT=8000

# ─── Groq API ────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
# Supported free models: llama-3.3-70b-versatile, llama3-8b-8192, mixtral-8x7b-32768
GROQ_API_KEY=your-groq-api-key-here

# Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated) for CORS
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173,https://miniproject-ckza.onrender.com,https://www.chatsconnect.tech
