# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use strong, random secrets in production (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Full URL of the deployed backend (used for OAuth callback URL)
BACKEND_URL=https://miniproject-ckza.onrender.com

# Full URL of the deployed frontend (used for CORS allow-list)
CLIENT_URL=https://mini-project-omega-ochre.vercel.app

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_USER=your-email@gmail.com
# Use a Gmail App Password, NOT your real password
EMAIL_PASSWORD=your-app-password

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── AI Microservice ──────────────────────────────────────────────────────────
# URL of the FastAPI AI server (defaults to localhost:8000 if not set)
AI_SERVICE_URL=http://localhost:8000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
